# Copy this file to .env when you are ready to connect real services.
#
# The demo runs without any keys. Real rendering/captioning workflows should read
# these variables from the local machine only. Never commit .env.

PORT=8783

# Optional video generation provider key.
# Example: Runway, HeyGen, Higgsfield, or your own generation service.
VIDEO_PROVIDER_API_KEY=

# Submagic creates/edit captions for short-form videos.
# Add your Submagic API key here only if you wire the real captioning endpoint.
SUBMAGIC_API_KEY=

# Optional music/render settings.
MUSIC_VOLUME_PERCENT=15
MUSIC_START_SECONDS=5
